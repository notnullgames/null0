// GamepadButton: Represents a gamepad button.
const GAMEPAD_BUTTON_UNKNOWN: i32 = 0;
const GAMEPAD_BUTTON_UP: i32 = 1;
const GAMEPAD_BUTTON_RIGHT: i32 = 2;
const GAMEPAD_BUTTON_DOWN: i32 = 3;
const GAMEPAD_BUTTON_LEFT: i32 = 4;
