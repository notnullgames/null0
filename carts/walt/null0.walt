// null0 - walt bindings for the null0 fantasy console
//
// walt imports are per-module, so copy the imports you need from this file
// into your own cart, like:
//
//   type Clear = (i32) => void;
//   import { clear: Clear } from 'null0';
//
//   export function load(): void {
//     clear(BLUE);
//   }
//
// ABI notes:
// - all handles (Image/Font/Sound), enums, bools and pointers are i32
// - string is a pointer to a null-terminated UTF8 string in memory (i32)
// - Color is 4 bytes packed into a single i32: r | g<<8 | b<<16 | a<<24
// - functions returning structs (Vector/Dimensions/Rectangle/Color/SfxParams)
//   return a pointer (i32) into your memory

// constants

const SCREEN: i32 = 0;
const SCREEN_WIDTH: i32 = 640;
const SCREEN_HEIGHT: i32 = 480;
const FONT_DEFAULT: i32 = 0;

// colors
const LIGHTGRAY: i32 = 0xffc8c8c8; // rgba(200, 200, 200, 255)
const GRAY: i32 = 0xff828282; // rgba(130, 130, 130, 255)
const DARKGRAY: i32 = 0xff505050; // rgba(80, 80, 80, 255)
const YELLOW: i32 = 0xff00f9fd; // rgba(253, 249, 0, 255)
const GOLD: i32 = 0xff00cbff; // rgba(255, 203, 0, 255)
const ORANGE: i32 = 0xff00a1ff; // rgba(255, 161, 0, 255)
const PINK: i32 = 0xffc26dff; // rgba(255, 109, 194, 255)
const RED: i32 = 0xff3729e6; // rgba(230, 41, 55, 255)
const MAROON: i32 = 0xff3721be; // rgba(190, 33, 55, 255)
const GREEN: i32 = 0xff30e400; // rgba(0, 228, 48, 255)
const LIME: i32 = 0xff2f9e00; // rgba(0, 158, 47, 255)
const DARKGREEN: i32 = 0xff2c7500; // rgba(0, 117, 44, 255)
const SKYBLUE: i32 = 0xffffbf66; // rgba(102, 191, 255, 255)
const BLUE: i32 = 0xfff17900; // rgba(0, 121, 241, 255)
const DARKBLUE: i32 = 0xffac5200; // rgba(0, 82, 172, 255)
const PURPLE: i32 = 0xffff7ac8; // rgba(200, 122, 255, 255)
const VIOLET: i32 = 0xffbe3c87; // rgba(135, 60, 190, 255)
const DARKPURPLE: i32 = 0xff7e1f70; // rgba(112, 31, 126, 255)
const BEIGE: i32 = 0xff83b0d3; // rgba(211, 176, 131, 255)
const BROWN: i32 = 0xff4f6a7f; // rgba(127, 106, 79, 255)
const DARKBROWN: i32 = 0xff2f3f4c; // rgba(76, 63, 47, 255)
const WHITE: i32 = 0xffffffff; // rgba(255, 255, 255, 255)
const BLACK: i32 = 0xff000000; // rgba(0, 0, 0, 255)
const BLANK: i32 = 0x00000000; // rgba(0, 0, 0, 0)
const MAGENTA: i32 = 0xffff00ff; // rgba(255, 0, 255, 255)
const RAYWHITE: i32 = 0xfff5f5f5; // rgba(245, 245, 245, 255)


// ImageFilter: Potential image-filtering techniques for scale/etc.
const FILTER_NEARESTNEIGHBOR: i32 = 0;
const FILTER_BILINEAR: i32 = 1;
