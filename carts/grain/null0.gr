// null0 - Grain bindings for the null0 fantasy console
//
// Grain needs foreign declarations inside your own module, so copy the
// ones you need from this file, like:
//
//   module Main
//
//   from "runtime/unsafe/wasmi32" include WasmI32
//
//   foreign wasm clear: (WasmI32) => Void from "null0"
//
//   @unsafe
//   provide let load = () => {
//     clear(WasmI32.fromGrain(blue))
//   }
//
//   provide let update = () => void
//
// ABI notes:
// - all handles (Image/Font/Sound), enums, bools and pointers are WasmI32
// - string is a pointer to a null-terminated UTF8 string in memory (WasmI32)
// - Color is 4 bytes packed into a single i32: r | g<<8 | b<<16 | a<<24
//   (the color constants below are plain Numbers, wrap them with
//   WasmI32.fromGrain() when calling)
// - functions returning structs (Vector/Dimensions/Rectangle/Color/SfxParams)
//   return a pointer (WasmI32) into your memory
// - anything touching Wasm types needs an @unsafe attribute

// constants

let SCREEN = 0
let SCREEN_WIDTH = 640
let SCREEN_HEIGHT = 480
let FONT_DEFAULT = 0

// colors (packed r | g<<8 | b<<16 | a<<24)
let lightgray = 0xffc8c8c8 // LIGHTGRAY = rgba(200, 200, 200, 255)
let gray = 0xff828282 // GRAY = rgba(130, 130, 130, 255)
let darkgray = 0xff505050 // DARKGRAY = rgba(80, 80, 80, 255)
let yellow = 0xff00f9fd // YELLOW = rgba(253, 249, 0, 255)
let gold = 0xff00cbff // GOLD = rgba(255, 203, 0, 255)
let orange = 0xff00a1ff // ORANGE = rgba(255, 161, 0, 255)
let pink = 0xffc26dff // PINK = rgba(255, 109, 194, 255)
let red = 0xff3729e6 // RED = rgba(230, 41, 55, 255)
let maroon = 0xff3721be // MAROON = rgba(190, 33, 55, 255)
let green = 0xff30e400 // GREEN = rgba(0, 228, 48, 255)
let lime = 0xff2f9e00 // LIME = rgba(0, 158, 47, 255)
let darkgreen = 0xff2c7500 // DARKGREEN = rgba(0, 117, 44, 255)
let skyblue = 0xffffbf66 // SKYBLUE = rgba(102, 191, 255, 255)
let blue = 0xfff17900 // BLUE = rgba(0, 121, 241, 255)
let darkblue = 0xffac5200 // DARKBLUE = rgba(0, 82, 172, 255)
let purple = 0xffff7ac8 // PURPLE = rgba(200, 122, 255, 255)
let violet = 0xffbe3c87 // VIOLET = rgba(135, 60, 190, 255)
let darkpurple = 0xff7e1f70 // DARKPURPLE = rgba(112, 31, 126, 255)
let beige = 0xff83b0d3 // BEIGE = rgba(211, 176, 131, 255)
let brown = 0xff4f6a7f // BROWN = rgba(127, 106, 79, 255)
let darkbrown = 0xff2f3f4c // DARKBROWN = rgba(76, 63, 47, 255)
let white = 0xffffffff // WHITE = rgba(255, 255, 255, 255)
let black = 0xff000000 // BLACK = rgba(0, 0, 0, 255)
let blank = 0x00000000 // BLANK = rgba(0, 0, 0, 0)
let magenta = 0xffff00ff // MAGENTA = rgba(255, 0, 255, 255)
let raywhite = 0xfff5f5f5 // RAYWHITE = rgba(245, 245, 245, 255)


