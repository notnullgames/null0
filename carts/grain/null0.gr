// -- INPUT --

// Has the key been pressed? (tracks unpress/read correctly.)
foreign wasm key_pressed: (WasmI32) => WasmI32 from "null0"
// Is the key currently down?
foreign wasm key_down: (WasmI32) => WasmI32 from "null0"
// Has the key been released? (tracks press/read correctly.)
foreign wasm key_released: (WasmI32) => WasmI32 from "null0"
// Is the key currently up?
foreign wasm key_up: (WasmI32) => WasmI32 from "null0"
// Has the button been pressed? (tracks unpress/read correctly.)
foreign wasm gamepad_button_pressed: (WasmI32, WasmI32) => WasmI32 from "null0"
// Is the button currently down?
foreign wasm gamepad_button_down: (WasmI32, WasmI32) => WasmI32 from "null0"
// Has the button been released? (tracks press/read correctly.)
foreign wasm gamepad_button_released: (WasmI32, WasmI32) => WasmI32 from "null0"
// Get current position of mouse.
foreign wasm mouse_position: () => WasmI32 from "null0"
// Has the button been pressed? (tracks unpress/read correctly.)
foreign wasm mouse_button_pressed: (WasmI32) => WasmI32 from "null0"
// Is the button currently down?
foreign wasm mouse_button_down: (WasmI32) => WasmI32 from "null0"
// Has the button been released? (tracks press/read correctly.)
foreign wasm mouse_button_released: (WasmI32) => WasmI32 from "null0"
// Is the button currently up?
foreign wasm mouse_button_up: (WasmI32) => WasmI32 from "null0"

// -- SOUND --

// Load a sound from a file in cart.
foreign wasm load_sound: (WasmI32) => WasmI32 from "null0"
// Play a sound.
